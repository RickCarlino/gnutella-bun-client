{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "bun-types"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["gnutella.ts", "src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
